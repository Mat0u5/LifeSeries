{
	"schemaVersion": 1,
	"id": "${id}",
	"name": "${name}",
	"version": "${version}",
	"authors": ["${authors}"],
	"contributors": ["${contributors}"],
	"contact": {
		"sources": "${sources_url}",
		"issues": "${issues_url}",
		"homepage": "${homepage_url}"
	},
	"description": "${description}",
	"icon": "icon.png",
	"license": "${license}",
	"environment": "*",
